---
import { defaultLocale, type Locale, isLocale } from "../i18n/ui";
import {
	categoryHref,
	formatDate,
	formatReadingTime,
	tagHref,
} from "../utils/blog";

interface Props {
	category: string;
	description: string;
	lang?: Locale;
	pubDate: Date;
	readingTimeMinutes: number;
	tags?: string[];
	title: string;
}

const {
	category,
	description,
	lang: langProp,
	pubDate,
	readingTimeMinutes,
	tags = [],
	title,
} = Astro.props;

const lang = isLocale(langProp) ? langProp : defaultLocale;
const categoryLink = categoryHref(category, lang);
---

<header class="space-y-6 border-b border-dawn-300 pb-10 dark:border-night-600">
	<div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-dawn-600 dark:text-night-300">
		<a
			href={categoryLink}
			class="transition-colors hover:text-dawn-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-dawn-300 focus-visible:ring-offset-2 focus-visible:ring-offset-dawn-100 dark:hover:text-night-50 dark:focus-visible:ring-night-500 dark:focus-visible:ring-offset-night-800"
		>
			{category}
		</a>
		<span aria-hidden="true">·</span>
		<time datetime={pubDate.toISOString().slice(0, 10)}>{formatDate(pubDate)}</time>
		<span aria-hidden="true">·</span>
		<p>{formatReadingTime(readingTimeMinutes, lang)}</p>
	</div>

	<div class="space-y-4">
		<h1 class="text-4xl font-semibold tracking-tight text-dawn-800 dark:text-night-50 sm:text-5xl">
			{title}
		</h1>
		<p class="max-w-2xl text-lg leading-8 text-dawn-700 dark:text-night-200">
			{description}
		</p>
	</div>

	{
		tags.length > 0 && (
			<ul class="flex flex-wrap gap-2">
				{tags.map((tag) => (
					<li>
						<a
							href={tagHref(tag, lang)}
							class="inline-flex rounded-full bg-dawn-200 px-3 py-1 text-sm text-dawn-700 transition-colors hover:bg-dawn-300 hover:text-dawn-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-dawn-300 focus-visible:ring-offset-2 focus-visible:ring-offset-dawn-100 dark:bg-night-900 dark:text-night-200 dark:hover:bg-night-700 dark:hover:text-night-50 dark:focus-visible:ring-night-500 dark:focus-visible:ring-offset-night-800"
						>
							#{tag}
						</a>
					</li>
				))}
			</ul>
		)
	}
</header>
