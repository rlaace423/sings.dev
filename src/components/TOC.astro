---
interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	headings?: Heading[];
	title?: string;
	ariaLabel?: string;
}

const {
	headings = [],
	title = "On this page",
	ariaLabel = "Table of contents",
} = Astro.props;
const items = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

{
	items.length > 0 && (
		<nav data-toc aria-label={ariaLabel} class="text-sm text-dawn-700 dark:text-night-200">
			<p class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-dawn-600 dark:text-night-400">
				{title}
			</p>
			<ul class="space-y-2">
				{items.map((heading) => (
					<li class:list={[heading.depth > 2 && "pl-4"]}>
						<a
							href={`#${heading.slug}`}
							class="toc-link block leading-6 text-dawn-700 transition-colors hover:text-dawn-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-dawn-300 focus-visible:ring-offset-2 focus-visible:ring-offset-dawn-100 dark:text-night-200 dark:hover:text-night-50 dark:focus-visible:ring-night-500 dark:focus-visible:ring-offset-night-800"
						>
							{heading.text}
						</a>
					</li>
				))}
			</ul>
		</nav>
	)
}

<script is:inline>
	(() => {
		if (window.__tocScrollSpyInit) return;
		window.__tocScrollSpyInit = true;

		function init() {
			// Derive the tracked heading set from the TOC links themselves so we
			// follow only the headings the TOC component decided to surface (h2 +
			// h3 inside the post body) and never accidentally pick up an h2 from
			// elsewhere on the page (e.g. the comments section heading).
			const tocLinks = Array.from(
				document.querySelectorAll('nav[data-toc] a[href^="#"]'),
			);
			if (tocLinks.length === 0) return;

			// Build id -> [...links] so both the desktop sticky TOC and the mobile
			// <details> TOC update together. The mobile one is hidden until the
			// user opens the <details>, but its active state stays correct.
			const linksByHash = new Map();
			for (const link of tocLinks) {
				const href = link.getAttribute("href");
				if (!href || !href.startsWith("#") || href.length < 2) continue;
				const id = href.slice(1);
				if (!linksByHash.has(id)) linksByHash.set(id, []);
				linksByHash.get(id).push(link);
			}
			if (linksByHash.size === 0) return;

			// Resolve headings in document order. The TOC renders headings in
			// document order, so iterating linksByHash keys gives us the same.
			const headings = [];
			for (const id of linksByHash.keys()) {
				const el = document.getElementById(id);
				if (el) headings.push(el);
			}
			if (headings.length === 0) return;

			// `scroll-padding-top` on <html> reserves space for the sticky site
			// header so anchor jumps land below it. Read the same value here so the
			// scroll-spy trigger line accounts for the header — without this, the
			// trigger sits 25% below the very top of the viewport (well below the
			// just-clicked heading after a TOC click) and on dense H2/H3 layouts
			// the next heading creeps above the trigger before the click-scroll
			// even settles, causing the active class to jump one row down right
			// after the click.
			function readHeaderOffset() {
				const raw = getComputedStyle(document.documentElement).scrollPaddingTop;
				const parsed = parseFloat(raw);
				return Number.isFinite(parsed) ? parsed : 0;
			}

			function clearActive() {
				for (const links of linksByHash.values()) {
					for (const link of links) link.classList.remove("toc-active");
				}
			}

			function setActive(id) {
				for (const [otherId, links] of linksByHash) {
					const isActive = otherId === id;
					for (const link of links) {
						link.classList.toggle("toc-active", isActive);
					}
				}
			}

			let ticking = false;
			function updateActive() {
				// Trigger line at 25% of the viewport, then pulled UP by the header
				// offset so the trigger sits just below the sticky header in
				// viewport coordinates. After a TOC click the clicked heading lands
				// at viewport y = headerOffset; the trigger lands a few pixels
				// further down, so only the clicked heading is "above the trigger"
				// even on densely-spaced H2/H3 layouts. Adding the offset (the
				// previous formulation) would have moved the trigger DOWN and
				// widened the window in which the next heading also activates,
				// which is the opposite of the intended fix.
				const triggerY =
					window.scrollY + window.innerHeight * 0.25 - readHeaderOffset();
				let activeId = null;
				for (const heading of headings) {
					if (heading.offsetTop <= triggerY) {
						activeId = heading.id;
					} else {
						break;
					}
				}
				if (activeId) {
					setActive(activeId);
				} else {
					// Reader hasn't reached the first heading yet — leave the TOC
					// unhighlighted rather than falsely activating the first link.
					clearActive();
				}
			}

			function onScrollOrResize() {
				if (!ticking) {
					window.requestAnimationFrame(() => {
						updateActive();
						ticking = false;
					});
					ticking = true;
				}
			}

			window.addEventListener("scroll", onScrollOrResize, { passive: true });
			window.addEventListener("resize", onScrollOrResize, { passive: true });
			updateActive();
		}

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", init);
		} else {
			init();
		}
	})();
</script>
