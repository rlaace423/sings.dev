---
import type { CollectionEntry } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import { defaultLocale, type Locale, isLocale } from "../i18n/ui";
import {
	categoryHref,
	formatDate,
	getDisplayTitle,
	slugifyTaxonomy,
	stripLocaleFromId,
	tagHref,
} from "../utils/blog";

interface Props {
	posts: CollectionEntry<"blog">[];
	emptyMessage?: string;
	filterable?: boolean;
	lang?: Locale;
}

const {
	posts,
	emptyMessage = "No posts found yet.",
	filterable = false,
	lang: langProp,
} = Astro.props;
const lang = isLocale(langProp) ? langProp : defaultLocale;
---

{
	posts.length > 0 ? (
		<ul class="divide-y divide-stone-200 border-t border-stone-200 dark:divide-stone-800 dark:border-stone-800">
			{posts.map((post) => (
				<li
					class="py-8"
					data-post-item={filterable ? "" : undefined}
					data-category={
						filterable ? slugifyTaxonomy(post.data.category) : undefined
					}
					data-tags={
						filterable
							? (post.data.tags ?? []).map(slugifyTaxonomy).join(",")
							: undefined
					}
				>
					<article class="space-y-4">
						<div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-sm">
							<a
								href={
									lang === defaultLocale
										? categoryHref(post.data.category)
										: getRelativeLocaleUrl(
												lang,
												`category/${slugifyTaxonomy(post.data.category)}`,
											)
								}
								class="rounded-full border border-stone-200 px-3 py-1 text-stone-700 transition-colors hover:border-stone-300 hover:text-stone-950 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-300 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50 dark:border-stone-800 dark:text-stone-200 dark:hover:border-stone-700 dark:hover:text-stone-50 dark:focus-visible:ring-stone-700 dark:focus-visible:ring-offset-stone-950"
							>
								{post.data.category ?? "Uncategorized"}
							</a>
							<p class="text-stone-500 dark:text-stone-500">
								{formatDate(post.data.pubDate)}
							</p>
						</div>

						<h2 class="text-2xl font-semibold tracking-tight text-stone-950 dark:text-stone-50">
							<a
								href={getRelativeLocaleUrl(
									lang,
									`posts/${stripLocaleFromId(post.id)}`,
								)}
								class="transition-colors hover:text-stone-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-300 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50 dark:hover:text-stone-300 dark:focus-visible:ring-stone-700 dark:focus-visible:ring-offset-stone-950"
							>
								{getDisplayTitle(post)}
							</a>
						</h2>

						<p class="max-w-2xl leading-8 text-stone-600 dark:text-stone-300">
							{post.data.description}
						</p>

						{
							(post.data.tags?.length ?? 0) > 0 && (
								<ul class="flex flex-wrap gap-2">
									{post.data.tags?.map((tag) => (
										<li>
											<a
												href={
													lang === defaultLocale
														? tagHref(tag)
														: getRelativeLocaleUrl(
																lang,
																`tags/${slugifyTaxonomy(tag)}`,
															)
												}
												class="inline-flex rounded-full bg-stone-100 px-3 py-1 text-sm text-stone-600 transition-colors hover:bg-stone-200 hover:text-stone-950 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-300 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50 dark:bg-stone-900 dark:text-stone-300 dark:hover:bg-stone-800 dark:hover:text-stone-50 dark:focus-visible:ring-stone-700 dark:focus-visible:ring-offset-stone-950"
											>
												#{tag}
											</a>
										</li>
									))}
								</ul>
							)
						}
					</article>
				</li>
			))}
		</ul>
	) : (
		<div class="border-t border-stone-200 py-8 text-stone-600 dark:border-stone-800 dark:text-stone-300">
			<p>{emptyMessage}</p>
		</div>
	)
}
