---
import SocialIcon, { type SocialType } from "./SocialIcon.astro";
import { defaultLocale, type Locale, isLocale } from "../i18n/ui";

interface Photo {
	src: string;
	alt: string;
}

interface SocialLink {
	type: SocialType;
	href: string;
	label?: string;
}

interface EducationEntry {
	school: string;
	degree: string;
	start?: string;
	end?: string;
	description?: string;
}

interface ExperienceEntry {
	company: string;
	role: string;
	start: string;
	end: string;
	description: string;
}

interface Props {
	lang?: Locale;
	name: string;
	summary: string;
	photo: Photo;
	socials?: SocialLink[];
	education?: EducationEntry[];
	experience?: ExperienceEntry[];
}

const {
	lang: langProp,
	name,
	summary,
	photo,
	socials = [],
	education = [],
	experience = [],
} = Astro.props;

const lang = isLocale(langProp) ? langProp : defaultLocale;
const educationHeading = lang === "ko" ? "학력" : "Education";
const experienceHeading = lang === "ko" ? "경력" : "Experience";
const socialsLabel = lang === "ko" ? "연락처와 프로필" : "Contact and profiles";
---

<div class="space-y-12">
	<h1
		data-about-name
		class="text-4xl font-semibold tracking-tight text-dawn-800 dark:text-night-50 sm:text-5xl"
	>
		{name}
	</h1>

	<section class="space-y-8">
		<div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:gap-8">
			<img
				src={photo.src}
				alt={photo.alt}
				width="96"
				height="96"
				class="h-24 w-24 shrink-0 rounded-full bg-dawn-200 object-cover ring-1 ring-dawn-300 dark:bg-night-700 dark:ring-night-600"
			/>
			<p
				data-about-summary
				class="max-w-2xl text-lg leading-8 text-dawn-700 dark:text-night-200"
			>
				{summary}
			</p>
		</div>

		{
			socials.length > 0 && (
				<ul
					data-about-socials
					aria-label={socialsLabel}
					class="flex flex-wrap gap-x-5 gap-y-3 text-sm text-dawn-700 dark:text-night-200"
				>
					{socials.map((item) => (
						<li>
							<a
								href={item.href}
								rel={item.type === "email" ? undefined : "me noopener"}
								class="inline-flex items-center gap-2 transition-colors hover:text-dawn-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-dawn-300 focus-visible:ring-offset-2 focus-visible:ring-offset-dawn-100 dark:hover:text-night-50 dark:focus-visible:ring-night-500 dark:focus-visible:ring-offset-night-800"
							>
								<SocialIcon type={item.type} class="h-4 w-4" />
								<span>{item.label ?? item.type}</span>
							</a>
						</li>
					))}
				</ul>
			)
		}
	</section>

	{
		education.length > 0 && (
			<section class="space-y-6">
				<h2 class="text-2xl font-semibold tracking-tight text-dawn-800 dark:text-night-50">
					{educationHeading}
				</h2>
				<ol
					data-about-education
					class="divide-y divide-dawn-300 border-t border-dawn-300 dark:divide-night-600 dark:border-night-600"
				>
					{education.map((entry) => (
						<li class="py-6">
							<p class="text-base font-semibold text-dawn-800 dark:text-night-50">
								{entry.school}
							</p>
							<p class="mt-1 text-sm text-dawn-700 dark:text-night-200">{entry.degree}</p>
							{entry.description && (
								<p class="mt-3 max-w-2xl leading-7 text-dawn-700 dark:text-night-200">
									{entry.description}
								</p>
							)}
						</li>
					))}
				</ol>
			</section>
		)
	}

	{
		experience.length > 0 && (
			<section class="space-y-6">
				<h2 class="text-2xl font-semibold tracking-tight text-dawn-800 dark:text-night-50">
					{experienceHeading}
				</h2>
				<ol
					data-about-experience
					class="divide-y divide-dawn-300 border-t border-dawn-300 dark:divide-night-600 dark:border-night-600"
				>
					{experience.map((entry) => (
						<li class="grid gap-4 py-6 sm:grid-cols-[minmax(7rem,auto)_1fr] sm:gap-8">
							<p class="text-sm tabular-nums text-dawn-600 dark:text-night-400">
								<span>{entry.start}</span>
								<span aria-hidden="true"> — </span>
								<span>{entry.end}</span>
							</p>
							<div class="space-y-1">
								<p class="text-base font-semibold text-dawn-800 dark:text-night-50">
									{entry.company}
								</p>
								<p class="text-sm text-dawn-700 dark:text-night-200">{entry.role}</p>
								<p class="mt-3 max-w-2xl leading-7 text-dawn-700 dark:text-night-200">
									{entry.description}
								</p>
							</div>
						</li>
					))}
				</ol>
			</section>
		)
	}
</div>
