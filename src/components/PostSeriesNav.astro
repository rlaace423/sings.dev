---
import { defaultLocale, type Locale, isLocale } from "../i18n/ui";

interface SeriesItem {
	href: string;
	label: string;
}

interface Series {
	currentIndex: number;
	items: SeriesItem[];
	title: string;
}

interface Props {
	lang?: Locale;
	series?: Series | null;
}

const { lang: langProp, series } = Astro.props;
const lang = isLocale(langProp) ? langProp : defaultLocale;
const labels = lang === "ko"
	? {
			heading: "이 시리즈",
			current: "현재 위치",
			previous: "이전",
			next: "다음",
		}
	: {
			heading: "In This Series",
			current: "Current chapter",
			previous: "Previous",
			next: "Next",
		};

const items = series?.items ?? [];
const currentIndex = series ? Math.min(Math.max(series.currentIndex, 0), Math.max(items.length - 1, 0)) : 0;
const previousItem = currentIndex > 0 ? items[currentIndex - 1] : undefined;
const nextItem = currentIndex < items.length - 1 ? items[currentIndex + 1] : undefined;
---

{
	series?.title && items.length > 0 && (
		<section class="space-y-4">
			<div class="space-y-2">
				<p class="text-xs font-semibold uppercase tracking-[0.2em] text-dawn-600 dark:text-night-400">
					{labels.heading}
				</p>
				<div class="space-y-1">
					<p class="text-lg font-medium tracking-tight text-dawn-800 dark:text-night-50">
						{series.title}
					</p>
					<p class="text-xs tabular-nums uppercase tracking-[0.18em] text-dawn-600 dark:text-night-400">
						{currentIndex + 1} / {items.length}
					</p>
				</div>
			</div>

			<div class="flex flex-wrap gap-3 text-sm">
				{
					previousItem && (
						<a
							href={previousItem.href}
							class="inline-flex items-center gap-2 text-dawn-700 transition-colors hover:text-dawn-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-dawn-300 focus-visible:ring-offset-2 focus-visible:ring-offset-dawn-100 dark:text-night-200 dark:hover:text-night-50 dark:focus-visible:ring-night-500 dark:focus-visible:ring-offset-night-800"
						>
							<span class="text-xs uppercase tracking-[0.18em] text-dawn-600 dark:text-night-400">
								{labels.previous}
							</span>
							<span>{previousItem.label}</span>
						</a>
					)
				}
				{
					nextItem && (
						<a
							href={nextItem.href}
							class="inline-flex items-center gap-2 text-dawn-700 transition-colors hover:text-dawn-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-dawn-300 focus-visible:ring-offset-2 focus-visible:ring-offset-dawn-100 dark:text-night-200 dark:hover:text-night-50 dark:focus-visible:ring-night-500 dark:focus-visible:ring-offset-night-800"
						>
							<span class="text-xs uppercase tracking-[0.18em] text-dawn-600 dark:text-night-400">
								{labels.next}
							</span>
							<span>{nextItem.label}</span>
						</a>
					)
				}
			</div>

			<ol class="space-y-2 border-l border-dawn-300 pl-4 text-sm text-dawn-700 dark:border-night-600 dark:text-night-200">
				{items.map((item, index) => (
					<li class:list={[index === currentIndex && "text-dawn-800 dark:text-night-50"]}>
						<a
							href={item.href}
							aria-current={index === currentIndex ? "page" : undefined}
							class="block leading-6 transition-colors hover:text-dawn-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-dawn-300 focus-visible:ring-offset-2 focus-visible:ring-offset-dawn-100 dark:hover:text-night-50 dark:focus-visible:ring-night-500 dark:focus-visible:ring-offset-night-800"
						>
							<span>{item.label}</span>
							{index === currentIndex && (
								<span class="sr-only">{labels.current}</span>
							)}
						</a>
					</li>
				))}
			</ol>
		</section>
	)
}
