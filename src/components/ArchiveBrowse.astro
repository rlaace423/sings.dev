---
import { defaultLocale, type Locale, isLocale } from "../i18n/ui";
import { categoryHref, getCountLabel, tagHref } from "../utils/blog";

type ArchiveBrowseCategory = {
	name: string;
	description?: string;
	count: number;
};

interface Props {
	categories: ArchiveBrowseCategory[];
	tags: string[];
	lang?: Locale;
	title?: string;
	categoriesLabel?: string;
	tagsLabel?: string;
}

const {
	categories,
	tags,
	lang: langProp,
	title,
	categoriesLabel,
	tagsLabel,
} = Astro.props as Props;

const lang = isLocale(langProp) ? langProp : defaultLocale;
const browseTitle = title ?? (lang === "ko" ? "둘러보기" : "Browse");
const categoriesHeading =
	categoriesLabel ?? (lang === "ko" ? "카테고리" : "Categories");
const tagsHeading = tagsLabel ?? (lang === "ko" ? "대표 태그" : "Representative tags");

const getCategoryLink = (category: string) => categoryHref(category, lang);
const getTagLink = (tag: string) => tagHref(tag, lang);
---

<section class="mt-10 space-y-6 border-t border-dawn-300 pt-8 dark:border-night-600">
	<div class="space-y-2">
		<p class="text-xs font-semibold uppercase tracking-[0.18em] text-dawn-600 dark:text-night-400">
			{browseTitle}
		</p>
		<div class="space-y-8">
			<div class="space-y-3">
				<p class="text-sm font-medium text-dawn-700 dark:text-night-200">
					{categoriesHeading}
				</p>
				<ul class="space-y-3">
					{
						categories.map((category) => (
							<li class="border-b border-dawn-300 pb-3 last:border-0 last:pb-0 dark:border-night-600/80">
								<a
									href={getCategoryLink(category.name)}
									class="group block focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-dawn-300 focus-visible:ring-offset-2 focus-visible:ring-offset-dawn-100 dark:focus-visible:ring-night-500 dark:focus-visible:ring-offset-night-800"
								>
									<div class="space-y-1">
										<h2 class="text-lg font-medium text-dawn-800 transition-colors group-hover:text-dawn-700 dark:text-night-50 dark:group-hover:text-night-200">
											{category.name}
										</h2>
										{
											category.description ? (
												<p class="text-sm leading-6 text-dawn-700 dark:text-night-200">
													{category.description}
												</p>
											) : null
										}
										<p class="text-xs font-medium uppercase tracking-[0.18em] text-dawn-600 dark:text-night-300">
											{getCountLabel(category.count, lang)}
										</p>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</div>
			<div class="space-y-3">
				<p class="text-sm font-medium text-dawn-700 dark:text-night-200">
					{tagsHeading}
				</p>
				<ul class="flex flex-wrap gap-x-3 gap-y-2">
					{
						tags.map((tag) => (
							<li>
								<a
									href={getTagLink(tag)}
									class="inline-flex items-center gap-1 text-sm text-dawn-700 transition-colors hover:text-dawn-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-dawn-300 focus-visible:ring-offset-2 focus-visible:ring-offset-dawn-100 dark:text-night-200 dark:hover:text-night-50 dark:focus-visible:ring-night-500 dark:focus-visible:ring-offset-night-800"
								>
									#{tag}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>
	</div>
</section>
