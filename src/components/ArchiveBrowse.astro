---
import { getRelativeLocaleUrl } from "astro:i18n";
import { defaultLocale, type Locale, isLocale } from "../i18n/ui";
import { categoryHref, slugifyTaxonomy, tagHref } from "../utils/blog";

type ArchiveBrowseCategory = {
	name: string;
	description?: string;
	count: number;
};

interface Props {
	categories: ArchiveBrowseCategory[];
	tags: string[];
	lang?: Locale;
	title?: string;
	categoriesLabel?: string;
	tagsLabel?: string;
}

const {
	categories,
	tags,
	lang: langProp,
	title,
	categoriesLabel,
	tagsLabel,
} = Astro.props as Props;

const lang = isLocale(langProp) ? langProp : defaultLocale;
const browseTitle = title ?? (lang === "ko" ? "둘러보기" : "Browse");
const categoriesHeading =
	categoriesLabel ?? (lang === "ko" ? "카테고리" : "Categories");
const tagsHeading = tagsLabel ?? (lang === "ko" ? "대표 태그" : "Representative tags");
const getCountLabel = (count: number) =>
	lang === "ko" ? `${count}개의 글` : `${count} ${count === 1 ? "post" : "posts"}`;

const getCategoryLink = (category: string) =>
	lang === defaultLocale
		? categoryHref(category)
		: getRelativeLocaleUrl(lang, `category/${slugifyTaxonomy(category)}`);

const getTagLink = (tag: string) =>
	lang === defaultLocale
		? tagHref(tag)
		: getRelativeLocaleUrl(lang, `tags/${slugifyTaxonomy(tag)}`);
---

<section class="mt-10 space-y-6 border-t border-stone-200 pt-8 dark:border-stone-800">
	<div class="space-y-2">
		<p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500 dark:text-stone-500">
			{browseTitle}
		</p>
		<div class="space-y-8">
			<div class="space-y-3">
				<p class="text-sm font-medium text-stone-600 dark:text-stone-300">
					{categoriesHeading}
				</p>
				<ul class="space-y-3">
					{
						categories.map((category) => (
							<li class="border-b border-stone-100 pb-3 last:border-0 last:pb-0 dark:border-stone-800/80">
								<a
									href={getCategoryLink(category.name)}
									class="group block focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-300 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50 dark:focus-visible:ring-stone-700 dark:focus-visible:ring-offset-stone-950"
								>
									<div class="space-y-1">
										<h2 class="text-lg font-medium text-stone-950 transition-colors group-hover:text-stone-700 dark:text-stone-50 dark:group-hover:text-stone-200">
											{category.name}
										</h2>
										{
											category.description ? (
												<p class="text-sm leading-6 text-stone-600 dark:text-stone-300">
													{category.description}
												</p>
											) : null
										}
										<p class="text-xs font-medium uppercase tracking-[0.18em] text-stone-500 dark:text-stone-400">
											{getCountLabel(category.count)}
										</p>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</div>
			<div class="space-y-3">
				<p class="text-sm font-medium text-stone-600 dark:text-stone-300">
					{tagsHeading}
				</p>
				<ul class="flex flex-wrap gap-x-3 gap-y-2">
					{
						tags.map((tag) => (
							<li>
								<a
									href={getTagLink(tag)}
									class="inline-flex items-center gap-1 text-sm text-stone-600 transition-colors hover:text-stone-950 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-300 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50 dark:text-stone-300 dark:hover:text-stone-50 dark:focus-visible:ring-stone-700 dark:focus-visible:ring-offset-stone-950"
								>
									#{tag}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>
	</div>
</section>
