---
import Layout from "../layouts/Layout.astro";

type Palette = {
	bg: string;
	textPrimary: string;
	textSecondary: string;
	textMuted: string;
	border: string;
	panel: string;
	accent: string;
	codeBg: string;
};

type Theme = {
	name: string;
	tagline: string;
	palette: Palette;
	notes: string;
};

const themes: Theme[] = [
	{
		name: "Current — Tailwind Stone",
		tagline: "Warm neutral gray. No named theme. Baseline we're on now.",
		palette: {
			bg: "#f5f5f4",
			textPrimary: "#1c1917",
			textSecondary: "#57534e",
			textMuted: "#78716c",
			border: "#d6d3d1",
			panel: "#e7e5e4",
			accent: "#1c1917",
			codeBg: "#e7e5e4",
		},
		notes:
			"Utility palette from Tailwind; no identity name. Reads like warm paper. Safest, most neutral choice.",
	},
	{
		name: "Tokyo Day",
		tagline: "Official light variant of Tokyo Night. Creates symmetry with the current dark mode.",
		palette: {
			bg: "#e1e2e7",
			textPrimary: "#3760bf",
			textSecondary: "#6172b0",
			textMuted: "#8990b3",
			border: "#b7c5d3",
			panel: "#c4c8da",
			accent: "#2e7de9",
			codeBg: "#c4c8da",
		},
		notes:
			"Cool blue-white. Perfect palette-family symmetry with the dark mode, but the canonical Tokyo Day text color is blue-tinted (not neutral black), which reads more IDE-like than editorial.",
	},
	{
		name: "Solarized Light",
		tagline: "Classic Ethan Schoonover palette. Warm cream bg with muted gray-green text.",
		palette: {
			bg: "#fdf6e3",
			textPrimary: "#586e75",
			textSecondary: "#657b83",
			textMuted: "#93a1a1",
			border: "#eee8d5",
			panel: "#eee8d5",
			accent: "#268bd2",
			codeBg: "#eee8d5",
		},
		notes:
			"Warm cream (base3). The canonical text colors trade some contrast for eye-strain ergonomics, which may fall short of WCAG AA for body text. Strong classic editorial feel if the contrast is acceptable.",
	},
	{
		name: "Catppuccin Latte",
		tagline: "Modern warm pastel from the Catppuccin community. Clean, gentle, neutral-warm.",
		palette: {
			bg: "#eff1f5",
			textPrimary: "#4c4f69",
			textSecondary: "#5c5f77",
			textMuted: "#8c8fa1",
			border: "#bcc0cc",
			panel: "#ccd0da",
			accent: "#1e66f5",
			codeBg: "#e6e9ef",
		},
		notes:
			"Sits between warm and cool. Actively maintained ecosystem across editors and terminals, so syntax highlighting stays coherent. Gentler contrast than Stone; slightly more character.",
	},
	{
		name: "Rosé Pine Dawn",
		tagline: "Warm rose/peach tints. Soft but distinctly character-driven.",
		palette: {
			bg: "#faf4ed",
			textPrimary: "#575279",
			textSecondary: "#797593",
			textMuted: "#9893a5",
			border: "#dfdad9",
			panel: "#f2e9e1",
			accent: "#d7827e",
			codeBg: "#f2e9e1",
		},
		notes:
			"Warmest pick with a distinct personality. The pink-leaning panel tone adds atmosphere but narrows the neutral space. Risk: rose can feel whimsical; reward: uniquely recognizable.",
	},
	{
		name: "H1 — Warm paper + muted ink-blue link",
		tagline: "Warm ivory bg, cool-tinted body ink (Tokyo Night's #24283b), classical editorial hyperlink blue.",
		palette: {
			bg: "#f5f3ee",
			textPrimary: "#24283b",
			textSecondary: "#4d5166",
			textMuted: "#7c8196",
			border: "#dcd6cc",
			panel: "#e8e3d9",
			accent: "#2c5282",
			codeBg: "#e8e3d9",
		},
		notes:
			"Primary text uses the dark mode's body bg hue (#24283b) as 'ink', so the two modes share one anchor color. Muted and secondary tones stay on neutral-warm grays — the muted text reads as quietly faded, matching what you said feels right. Link accent (#2c5282) is a deep ink blue: clearly 'this is a link' without shouting, and carries the book/web editorial hyperlink tradition.",
	},
	{
		name: "H2 — Warm paper + terracotta link",
		tagline: "Same warm paper + cool ink base, but link picks up a warm terracotta inspired by Tokyo Night's syntax orange.",
		palette: {
			bg: "#f5f3ee",
			textPrimary: "#24283b",
			textSecondary: "#4d5166",
			textMuted: "#7c8196",
			border: "#dcd6cc",
			panel: "#e8e3d9",
			accent: "#a04e2a",
			codeBg: "#e8e3d9",
		},
		notes:
			"Link accent (#a04e2a) is a muted terracotta — a desaturated, darker cousin of Tokyo Night's syntax orange (#ff9e64). Warm-on-warm pairs naturally with the ivory paper bg, and the color reads distinctly as 'link' without feeling like a generic blue web link. Gives the page a more literary/printed feel than ink-blue would.",
	},
	{
		name: "H3 — Warm paper + deep teal link",
		tagline: "Same warm paper + cool ink base, link accent is a deep teal from Tokyo Night's cyan family.",
		palette: {
			bg: "#f5f3ee",
			textPrimary: "#24283b",
			textSecondary: "#4d5166",
			textMuted: "#7c8196",
			border: "#dcd6cc",
			panel: "#e8e3d9",
			accent: "#0e7490",
			codeBg: "#e8e3d9",
		},
		notes:
			"Link accent (#0e7490) is Tokyo Night's signature cyan (#7dcfff) darkened for readability on a light warm bg. Cool-on-warm creates a subtle contrast pop — the link visibly 'is a link' and the cyan hue ties back to the syntax colors used inside Tokyo Night code blocks, so dark-mode readers encountering the link feel a familiar palette note.",
	},
];

const codeSample = `const splitByBoundary = (items) =>
  items.reduce((groups, item) => {
    const key = item.domain ?? "unassigned";
    groups[key] ??= [];
    groups[key].push(item);
    return groups;
  }, {});`;
---

<Layout
	title="Light Theme Preview | sings.dev"
	description="Side-by-side rendering of light-mode palette candidates for the site."
	lang="ko"
	contentClass="max-w-none"
>
	<article class="space-y-14">
		<header class="space-y-4">
			<p class="text-xs font-semibold uppercase tracking-[0.18em] text-dawn-600 dark:text-night-300">
				Utility page · delete after decision
			</p>
			<h1 class="text-4xl font-semibold tracking-tight text-dawn-800 dark:text-night-50 sm:text-5xl">
				Light Theme Preview
			</h1>
			<p class="max-w-2xl text-lg leading-8 text-dawn-700 dark:text-night-200">
				Each card below renders the same mini post sample using a candidate light-mode palette. Dark mode stays Tokyo
				Night Storm regardless — this page is only about the light side. Toggle the theme switch to confirm nothing breaks
				under dark, but comparisons should be done in light mode.
			</p>
			<p class="max-w-2xl text-sm leading-7 text-dawn-600 dark:text-night-300">
				Note: This is a vibe check, not a WCAG audit. Contrast values vary per palette and would need a separate pass
				before shipping the chosen theme.
			</p>
		</header>

		<section class="space-y-12">
			{
				themes.map((theme) => {
					const cardStyle = [
						`--bg:${theme.palette.bg}`,
						`--text-primary:${theme.palette.textPrimary}`,
						`--text-secondary:${theme.palette.textSecondary}`,
						`--text-muted:${theme.palette.textMuted}`,
						`--border:${theme.palette.border}`,
						`--panel:${theme.palette.panel}`,
						`--accent:${theme.palette.accent}`,
						`--code-bg:${theme.palette.codeBg}`,
					].join(";");

					return (
						<article class="theme-card space-y-6 rounded-lg p-8" style={cardStyle}>
							<header class="space-y-3">
								<p class="theme-card__name">{theme.name}</p>
								<p class="theme-card__tagline">{theme.tagline}</p>
								<ul class="theme-card__swatches">
									{(
										[
											["bg", theme.palette.bg, "body bg"],
											["primary", theme.palette.textPrimary, "text primary"],
											["secondary", theme.palette.textSecondary, "text secondary"],
											["muted", theme.palette.textMuted, "text muted"],
											["border", theme.palette.border, "border"],
											["panel", theme.palette.panel, "panel"],
											["accent", theme.palette.accent, "accent"],
											["code-bg", theme.palette.codeBg, "code bg"],
										] as const
									).map(([key, hex, label]) => (
										<li>
											<span class="theme-card__swatch" style={`background-color:${hex}`} />
											<span>
												{label} <code>{hex}</code>
											</span>
										</li>
									))}
								</ul>
							</header>

							<section class="theme-card__sample">
								<p class="theme-card__meta">
									ESSAY <span aria-hidden="true">·</span> 2026-04-23 <span aria-hidden="true">·</span> 5분 읽기
								</p>
								<h2 class="theme-card__title">차분한 시스템 설계에 대하여</h2>
								<p class="theme-card__description">
									복잡함보다 명료함을 선택할 때 남는 것들에 대한 짧은 기록. 같은 경계를 두 번 긋지 않도록 만드는 판단이
									시스템을 오래 유지하게 만든다.
								</p>
								<ul class="theme-card__tags">
									<li>#architecture</li>
									<li>#operations</li>
									<li>#quiet-systems</li>
								</ul>

								<hr class="theme-card__divider" />

								<aside class="theme-card__summary">
									<p class="theme-card__eyebrow">요약</p>
									<p>
										서비스 경계의 모호함을 없애는 가장 값싼 방법은, 경계가 생길 때마다 이름을 지어주고 그 이름을 코드와
										문서 양쪽에 쓰는 것이다. 이 글은 세 가지 사례를 짧게 정리한다.
									</p>
								</aside>

								<h3 class="theme-card__heading">경계를 이름으로 가두기</h3>
								<p class="theme-card__body">
									서비스 경계를 결정할 때 가장 먼저 확인해야 할 것은 <a href="#" class="theme-card__link">데이터 흐름</a>
									이다. 경계가 흐릿하면 <code class="theme-card__inline-code">getServiceBoundary()</code> 같은 단순
									호출조차 시간이 지나면서 의미를 잃는다. 그 모호함은 다른 팀원에게 추적 비용으로 전가된다.
								</p>

								<pre class="theme-card__code">
									<code>{codeSample}</code>
								</pre>

								<figure class="theme-card__figure">
									<div class="theme-card__figure-frame" aria-hidden="true">
										<span>figure placeholder</span>
									</div>
									<figcaption>caption rendered in the muted tone used across the site's figure system.</figcaption>
								</figure>
							</section>

							<footer class="theme-card__notes">
								<p>{theme.notes}</p>
							</footer>
						</article>
					);
				})
			}
		</section>
	</article>
</Layout>

<style>
	.theme-card {
		background-color: var(--bg);
		color: var(--text-primary);
		border: 1px solid var(--border);
	}

	.theme-card__name {
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.theme-card__tagline {
		font-size: 1.25rem;
		line-height: 1.75rem;
		color: var(--text-primary);
		max-width: 48rem;
	}

	.theme-card__swatches {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1.25rem;
		font-size: 0.75rem;
		color: var(--text-muted);
	}
	.theme-card__swatches li {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
	}
	.theme-card__swatch {
		display: inline-block;
		width: 1rem;
		height: 1rem;
		border-radius: 3px;
		border: 1px solid var(--border);
	}
	.theme-card__swatches code {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.72rem;
		color: var(--text-secondary);
	}

	.theme-card__sample {
		padding-top: 1.5rem;
		border-top: 1px dashed var(--border);
	}

	.theme-card__meta {
		font-size: 0.72rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--text-muted);
		margin-bottom: 1rem;
	}

	.theme-card__title {
		font-size: 2rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: var(--text-primary);
		margin-bottom: 0.75rem;
	}

	.theme-card__description {
		font-size: 1.125rem;
		line-height: 1.75rem;
		color: var(--text-secondary);
		max-width: 42rem;
		margin-bottom: 1.25rem;
	}

	.theme-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 1.75rem;
	}
	.theme-card__tags li {
		display: inline-flex;
		align-items: center;
		padding: 0.25rem 0.75rem;
		border-radius: 999px;
		background-color: var(--panel);
		color: var(--text-secondary);
		font-size: 0.875rem;
	}

	.theme-card__divider {
		border: none;
		border-top: 1px solid var(--border);
		margin: 1.5rem 0;
	}

	.theme-card__summary {
		border-left: 2px solid var(--text-muted);
		padding-left: 1.25rem;
		margin: 1.5rem 0 2rem;
	}
	.theme-card__eyebrow {
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--text-muted);
		margin-bottom: 0.5rem;
	}
	.theme-card__summary p:last-child {
		font-size: 1rem;
		line-height: 1.75rem;
		color: var(--text-secondary);
		max-width: 42rem;
	}

	.theme-card__heading {
		font-size: 1.375rem;
		font-weight: 600;
		letter-spacing: -0.005em;
		color: var(--text-primary);
		margin: 1.75rem 0 0.75rem;
	}

	.theme-card__body {
		font-size: 1rem;
		line-height: 1.75rem;
		color: var(--text-primary);
		max-width: 42rem;
		margin-bottom: 1.5rem;
	}

	.theme-card__link {
		color: var(--accent);
		text-underline-offset: 4px;
		text-decoration-color: color-mix(in srgb, var(--accent) 40%, transparent);
	}

	.theme-card__inline-code {
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.9em;
		background-color: var(--code-bg);
		padding: 0.125rem 0.375rem;
		border-radius: 3px;
		color: var(--text-primary);
	}

	.theme-card__code {
		background-color: var(--code-bg);
		color: var(--text-primary);
		border: 1px solid var(--border);
		border-radius: 6px;
		padding: 1rem 1.25rem;
		font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 0.875rem;
		line-height: 1.6;
		overflow-x: auto;
		margin-bottom: 1.75rem;
	}

	.theme-card__figure {
		margin: 0 0 0.5rem;
	}
	.theme-card__figure-frame {
		display: flex;
		align-items: center;
		justify-content: center;
		aspect-ratio: 16 / 9;
		background-color: var(--panel);
		border: 1px solid var(--border);
		border-radius: 6px;
		color: var(--text-muted);
		font-size: 0.75rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}
	.theme-card__figure figcaption {
		margin-top: 0.75rem;
		font-size: 0.875rem;
		font-style: italic;
		text-align: center;
		color: var(--text-muted);
	}

	.theme-card__notes {
		padding-top: 1rem;
		border-top: 1px dashed var(--border);
	}
	.theme-card__notes p {
		font-size: 0.9rem;
		line-height: 1.65;
		color: var(--text-muted);
		max-width: 48rem;
	}
</style>
