---
import ArchiveBrowse from "../../../components/ArchiveBrowse.astro";
import ArchiveFilters from "../../../components/ArchiveFilters.astro";
import Layout from "../../../layouts/Layout.astro";
import PostList from "../../../components/PostList.astro";
import { getCategoryDescription } from "../../../data/archiveBrowse";
import { getCollection } from "astro:content";
import {
	getTopTagsForPosts,
	isVisiblePost,
	matchesLocale,
	normalizeTaxonomyTags,
	sortPostsByDate,
	uniqueCategories,
	uniqueTags,
} from "../../../utils/blog";

const REPRESENTATIVE_TAG_LIMIT = 3;

const posts = sortPostsByDate(
	await getCollection("blog", (post) => matchesLocale(post.id, "en") && isVisiblePost(post)),
);
const categoryCounts = posts.reduce((counts, post) => {
	const category = post.data.category;
	if (!category) return counts;

	counts.set(category, (counts.get(category) ?? 0) + 1);
	return counts;
}, new Map<string, number>());
const categories = uniqueCategories(posts);
const tags = normalizeTaxonomyTags(uniqueTags(posts));
const browseCategories = categories.map((category) => ({
	name: category,
	description: getCategoryDescription("en", category),
	count: categoryCounts.get(category) ?? 0,
}));
const browseTags = getTopTagsForPosts(posts, REPRESENTATIVE_TAG_LIMIT);
---

<Layout
	title="Posts | sings.dev"
	description="An archive of English posts published on sings.dev."
	lang="en"
>
	<section class="space-y-4">
		<p class="text-sm uppercase tracking-[0.18em] text-dawn-600 dark:text-night-400">
			Archive
		</p>
		<h1 class="text-4xl font-semibold tracking-tight text-dawn-800 dark:text-night-50 sm:text-5xl">
			Posts
		</h1>
	</section>

	<ArchiveBrowse
		categories={browseCategories}
		tags={browseTags}
		lang={"en"}
	/>

	<ArchiveFilters
		categories={categories}
		tags={tags}
		filterLabel="Filter"
		categoryLabel="Categories"
		tagsLabel="Tags"
		allCategoriesLabel="All categories"
		categoryAriaLabel="Categories"
	/>

	<div class="mt-12 space-y-6" data-posts-archive>
		<p
			class="text-sm text-dawn-700 dark:text-night-200"
			data-results-count
		>
			{posts.length} posts in the archive
		</p>
		<PostList posts={posts} filterable lang="en" />
		<p
			class="hidden text-sm text-dawn-700 dark:text-night-200"
			data-empty-results
		>
			No posts match the current filters.
		</p>
	</div>

	<script>
		import { mountArchiveFilter } from "../../../utils/archiveFilter";

		mountArchiveFilter({
			format: "en",
			archiveSingular: "%count% post in the archive",
			archivePlural: "%count% posts in the archive",
			filteredSingular: "%count% post match the current filters",
			filteredPlural: "%count% posts match the current filters",
		});
	</script>
</Layout>
