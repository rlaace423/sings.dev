---
import { getRelativeLocaleUrl } from "astro:i18n";
import { getCollection } from "astro:content";
import { getCategoryDescription } from "../../../data/archiveBrowse";
import PostList from "../../../components/PostList.astro";
import Layout from "../../../layouts/Layout.astro";
import {
	getTopTagsForPosts,
	isVisiblePost,
	matchesLocale,
	normalizeTaxonomyTags,
	slugifyTaxonomy,
	sortPostsByDate,
	uniqueCategories,
} from "../../../utils/blog";

export async function getStaticPaths() {
	const posts = await getCollection("blog", (post) => matchesLocale(post.id, "en") && isVisiblePost(post));
	const categories = uniqueCategories(posts);

	return categories.map((category) => ({
		params: { category: slugifyTaxonomy(category) },
		props: {
			category,
			posts: sortPostsByDate(
				posts.filter((post) => post.data.category === category),
			),
		},
	}));
}

const { category, posts } = Astro.props;
const categoryDescription = getCategoryDescription("en", category);
const relatedTags = getTopTagsForPosts(posts, 8).filter((tag) =>
	posts.filter((post) =>
		normalizeTaxonomyTags(post.data.tags ?? []).includes(tag),
	).length >= 2,
).slice(0, 3);
---

<Layout
	title={`${category} | sings.dev`}
	description={categoryDescription || `Posts filed under ${category}.`}
	lang="en"
>
	<section class="space-y-4">
		<p class="text-sm uppercase tracking-[0.18em] text-stone-500 dark:text-stone-500">
			Category
		</p>
		<h1 class="text-4xl font-semibold tracking-tight text-stone-950 dark:text-stone-50 sm:text-5xl">
			{category}
		</h1>
		<p class="max-w-2xl text-lg leading-8 text-stone-600 dark:text-stone-300">
			{categoryDescription || "A filtered view of posts collected under this category."}
		</p>
		{
			relatedTags.length > 0 ? (
				<div class="space-y-3">
					<p class="text-sm font-medium text-stone-600 dark:text-stone-300">
						Related tags
					</p>
					<ul class="flex flex-wrap gap-x-3 gap-y-2">
						{relatedTags.map((tag) => (
							<li>
								<a
									href={getRelativeLocaleUrl(
										"en",
										`tags/${slugifyTaxonomy(tag)}`,
									)}
									class="inline-flex items-center gap-1 text-sm text-stone-600 transition-colors hover:text-stone-950 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-300 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50 dark:text-stone-300 dark:hover:text-stone-50 dark:focus-visible:ring-stone-700 dark:focus-visible:ring-offset-stone-950"
								>
									#{tag}
								</a>
							</li>
						))}
					</ul>
				</div>
			) : null
		}
	</section>

	<div class="mt-12 space-y-6">
		<p class="text-sm text-stone-600 dark:text-stone-300">
			{posts.length} posts in {category}
		</p>
		<PostList
			posts={posts}
			emptyMessage={`No posts are filed under ${category} yet.`}
			lang="en"
		/>
	</div>
</Layout>
