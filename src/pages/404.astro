---
import Layout from "../layouts/Layout.astro";

const localizedTitle = {
	ko: "404 — 페이지를 찾을 수 없습니다 | sings.dev",
	en: "404 — Page not found | sings.dev",
};

const localizedDescription = {
	ko: "요청하신 페이지가 존재하지 않거나, 주소가 바뀌었을 수 있습니다.",
	en: "The page you're looking for doesn't exist or has moved.",
};
---

<Layout title={localizedTitle} description={localizedDescription}>
	<article class="space-y-12 py-8">
		<section data-404-ko class="space-y-5">
			<p class="text-sm uppercase tracking-[0.18em] text-dawn-600 dark:text-night-400">404</p>
			<h1 class="text-4xl font-semibold tracking-tight text-dawn-800 dark:text-night-50 sm:text-5xl">
				페이지를 찾을 수 없습니다.
			</h1>
			<p class="leading-8 text-dawn-700 dark:text-night-200">
				주소가 바뀌었거나, 더 이상 존재하지 않는 페이지일 수 있습니다.{" "}
				<a href="/" class="text-terracotta-600 underline underline-offset-4 dark:text-night-100"
					>홈으로 돌아가기</a
				>.
			</p>
		</section>
		<section
			data-404-en
			lang="en"
			class="space-y-5 border-t border-dawn-300 pt-12 dark:border-night-600"
		>
			<p class="text-sm uppercase tracking-[0.18em] text-dawn-600 dark:text-night-400">404</p>
			<h2 class="text-4xl font-semibold tracking-tight text-dawn-800 dark:text-night-50 sm:text-5xl">
				Page not found.
			</h2>
			<p class="leading-8 text-dawn-700 dark:text-night-200">
				The page you're looking for has moved or no longer exists.{" "}
				<a href="/en/" class="text-terracotta-600 underline underline-offset-4 dark:text-night-100"
					>Back to the home page</a
				>.
			</p>
		</section>
	</article>

	<script is:inline>
		(() => {
			const isEn = window.location.pathname.startsWith("/en/");
			document.documentElement.dataset.notFoundLocale = isEn ? "en" : "ko";
			if (isEn) document.documentElement.lang = "en";
		})();
	</script>

	<style is:global>
		[data-not-found-locale="en"] [data-404-ko],
		[data-not-found-locale="ko"] [data-404-en] {
			display: none;
		}
		[data-not-found-locale="en"] [data-404-en] {
			border-top: 0;
			padding-top: 0;
		}
	</style>
</Layout>
