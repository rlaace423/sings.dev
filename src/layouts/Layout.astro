---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SearchModal from "../components/SearchModal.astro";
import { defaultLocale, locales, type Locale, isLocale } from "../i18n/ui";
import { getLocalizedSeoUrls } from "../utils/seo";
import "../styles/global.css";

type LocalizedValue = string | Partial<Record<Locale, string>>;

interface Props {
	title?: LocalizedValue;
	description?: LocalizedValue;
	lang?: Locale;
	contentClass?: string;
}

const {
	title = "sings.dev",
	description = "A minimalist Astro site for notes, posts, and essays.",
	lang: langProp = defaultLocale,
	contentClass = "max-w-3xl",
} = Astro.props;

const lang = isLocale(langProp) ? langProp : defaultLocale;
const seoUrls = Astro.site ? getLocalizedSeoUrls(Astro.site, Astro.url.pathname) : null;

const resolveLocalizedValue = (value: LocalizedValue) =>
	typeof value === "string" ? value : value[lang] ?? value[defaultLocale] ?? "";

const resolvedTitle = resolveLocalizedValue(title);
const resolvedDescription = resolveLocalizedValue(description);
---

<!doctype html>
<html lang={lang} class="bg-dawn-100 text-dawn-800 dark:bg-night-800 dark:text-night-100">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preload" href="/fonts/PretendardStdVariable.woff2" as="font" type="font/woff2" crossorigin />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={resolvedDescription} />
		{seoUrls && <link rel="canonical" href={seoUrls.canonical} />}
		{
			seoUrls &&
				locales.map((locale) => (
					<link rel="alternate" hreflang={locale} href={seoUrls.alternates[locale]} />
				))
		}
		{seoUrls && <link rel="alternate" hreflang="x-default" href={seoUrls.alternates[defaultLocale]} />}
		<title>{resolvedTitle}</title>
		<script is:inline>
			(() => {
				const storageKey = "theme";
				const root = document.documentElement;
				let storedTheme = null;

				try {
					storedTheme = localStorage.getItem(storageKey);
				} catch {}

				const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
				const isDark = storedTheme ? storedTheme === "dark" : prefersDark;

				root.classList.toggle("dark", isDark);
				root.style.colorScheme = isDark ? "dark" : "light";
			})();
		</script>
		</head>
		<body
			data-pagefind-filter={`language:${lang}`}
			class="flex min-h-screen flex-col bg-dawn-100 text-dawn-800 antialiased dark:bg-night-800 dark:text-night-100"
		>
			<Header lang={lang} />
			<div class="mx-auto flex w-full max-w-4xl flex-1 flex-col px-4 sm:px-6">
				<main class="flex-1 py-12 sm:py-16">
					<div class={contentClass}>
						<slot />
					</div>
				</main>
				<Footer />
			</div>
			<SearchModal lang={lang} />
			<script is:inline>
				(() => {
					if (window.__themeToggleInit) return;
					window.__themeToggleInit = true;

					const storageKey = "theme";
					const root = document.documentElement;
					const media = window.matchMedia("(prefers-color-scheme: dark)");

					const updateButtons = () => {
						const isDark = root.classList.contains("dark");
						const label = isDark ? "Switch to light mode" : "Switch to dark mode";

						document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
							button.setAttribute("aria-pressed", String(isDark));
							button.setAttribute("aria-label", label);

							const text = button.querySelector("[data-theme-label]");
							if (text) text.textContent = label;
						});
					};

					const applyTheme = (theme) => {
						const isDark = theme === "dark";
						root.classList.toggle("dark", isDark);
						root.style.colorScheme = isDark ? "dark" : "light";
						updateButtons();
					};

					const getPreferredTheme = () => {
						try {
							const storedTheme = localStorage.getItem(storageKey);
							if (storedTheme === "light" || storedTheme === "dark") {
								return storedTheme;
							}
						} catch {}

						return media.matches ? "dark" : "light";
					};

					applyTheme(getPreferredTheme());

					document.addEventListener("click", (event) => {
						const target = event.target;
						if (!(target instanceof Element)) return;

						const button = target.closest("[data-theme-toggle]");
						if (!button) return;

						const nextTheme = root.classList.contains("dark") ? "light" : "dark";

						root.classList.add("theme-transition");
						applyTheme(nextTheme);
						setTimeout(() => root.classList.remove("theme-transition"), 300);

						try {
							localStorage.setItem(storageKey, nextTheme);
						} catch {}
					});

					const handlePreferenceChange = (event) => {
						try {
							if (localStorage.getItem(storageKey)) return;
						} catch {}

						root.classList.add("theme-transition");
						applyTheme(event.matches ? "dark" : "light");
						setTimeout(() => root.classList.remove("theme-transition"), 300);
					};

					if (typeof media.addEventListener === "function") {
						media.addEventListener("change", handlePreferenceChange);
					} else {
						media.addListener(handlePreferenceChange);
					}
				})();
			</script>
		</body>
	</html>
